# Application
MOYUAN_APP_NAME=moyuan-shop-api
MOYUAN_APP_VERSION=0.1.0
MOYUAN_ENVIRONMENT=development
MOYUAN_DEBUG=true
MOYUAN_API_PREFIX=/api

# CORS
# Comma-separated values are supported by pydantic-settings for list fields.
MOYUAN_CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'

# Storage
# Relative paths are resolved from the backend working directory.
MOYUAN_STORAGE_DIR=storage
MOYUAN_STORAGE_BACKEND=minio
MOYUAN_PUBLIC_ASSET_BASE_URL=
MOYUAN_MINIO_ENDPOINT=127.0.0.1:9000
MOYUAN_MINIO_ACCESS_KEY=moyuan
MOYUAN_MINIO_SECRET_KEY=moyuan_minio_password
MOYUAN_MINIO_BUCKET=moyuan-images
MOYUAN_MINIO_SECURE=false

# Image Provider
# Use mock for local MVP, or openai to call the OpenAI-compatible gpt-image-2 provider.
MOYUAN_IMAGE_PROVIDER=mock
MOYUAN_DEFAULT_MODEL=gpt-image-2
MOYUAN_DEFAULT_SIZE=1024x1024
MOYUAN_DEFAULT_QUALITY=low
MOYUAN_DEFAULT_OUTPUT_FORMAT=jpeg
MOYUAN_DEFAULT_OUTPUT_COMPRESSION=50
MOYUAN_GENERATION_TIMEOUT_SECONDS=900
MOYUAN_MAX_GENERATION_COUNT=4

# OpenAI-compatible provider
# Used when MOYUAN_IMAGE_PROVIDER=openai.
# Keep these only in backend/.env, never in frontend env files.
OPENAI_BASE_URL=https://w.ciykj.cn/v1
OPENAI_API_KEY=

# Future persistence / queue placeholders
# MVP currently uses in-memory storage and local files.
MOYUAN_DATABASE_URL=sqlite:///./moyuan_shop.db
MOYUAN_REDIS_URL=redis://localhost:6379/0
